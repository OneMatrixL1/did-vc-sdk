    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aztec/bb.js": "4.2.0-aztecnr-rc.2",
    "@noir-lang/noir_js": "1.0.0-beta.19"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT"
}
