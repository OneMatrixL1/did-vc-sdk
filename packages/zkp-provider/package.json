{
  "name": "@1matrix/zkp-provider",
  "version": "0.1.0",
  "description": "Production ZKP provider for presentation-exchange — bundles compiled Noir circuits, Barretenberg WASM runtime, and Poseidon2 hasher",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "circuits"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@aztec/bb.js": ">=0.87.0",
    "@noir-lang/noir_js": ">=1.0.0-beta.11"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT"
}
